---
layout: layouts/base.njk
title: Observações
descricao: Registo de todas as observações de campo do Grupo icarus.
permalink: /observacoes/
---
<div class="container">

  <header class="obs-header">
    <div>
      <h1 class="titulo-secao">Observações de campo</h1>
      <p class="subtitulo" id="obs-subtitulo">Registo do Grupo icarus.</p>
      {% if observacoesInfo.ultimaAtualizacao %}
      <p class="obs-atualizado">Última actualização: {{ observacoesInfo.ultimaAtualizacao | dataPortugues }}</p>
      {% endif %}
    </div>
    <div class="obs-stats" id="obs-stats" style="display:none;">
      <a href="/estatisticas/observacoes/" class="obs-stat obs-stat-link" title="Ver estatísticas de observações">
        <span class="obs-stat-valor" id="stat-total">—</span>
        <span class="obs-stat-label">observações</span>
      </a>
      <a href="/estatisticas/especies/" class="obs-stat obs-stat-link" title="Ver estatísticas de espécies">
        <span class="obs-stat-valor" id="stat-especies">—</span>
        <span class="obs-stat-label">espécies</span>
      </a>
      <a href="/estatisticas/observadores/" class="obs-stat obs-stat-link" title="Ver estatísticas de observadores">
        <span class="obs-stat-valor" id="stat-observadores">—</span>
        <span class="obs-stat-label">observadores</span>
      </a>
    </div>
  </header>

  <div class="obs-filtros">
    <div class="obs-filtros-linha">
      <label class="obs-filtro-grupo">
        <span class="obs-filtro-label">Família</span>
        <select id="filtro-familia" class="obs-select">
          <option value="">Todas</option>
        </select>
      </label>
      <label class="obs-filtro-grupo">
        <span class="obs-filtro-label">Espécie</span>
        <select id="filtro-especie" class="obs-select" disabled>
          <option value="">— escolha uma família —</option>
        </select>
      </label>
      <label class="obs-filtro-grupo">
        <span class="obs-filtro-label">Ano</span>
        <select id="filtro-ano" class="obs-select">
          <option value="">Todos</option>
        </select>
      </label>
      <label class="obs-filtro-grupo">
        <span class="obs-filtro-label">Observador</span>
        <select id="filtro-observador" class="obs-select">
          <option value="">Todos</option>
        </select>
      </label>
    </div>
    <div class="obs-filtros-acoes">
      <span id="contagem-obs" class="obs-contagem"></span>
      <button id="limpar-filtros" class="obs-btn-limpar" style="display:none;">✕ Limpar filtros</button>
    </div>
  </div>

  <div class="obs-tabela-wrapper">
    <table id="tabela-obs" class="obs-tabela">
      <thead>
        <tr>
          <th>Data</th>
          <th>Espécie</th>
          <th>Família</th>
          <th>Quadrícula</th>
          <th class="obs-col-num">Qtd.</th>
          <th>Observador</th>
          <th>Notas</th>
        </tr>
      </thead>
      <tbody id="obs-tbody">
        <tr id="obs-loading">
          <td colspan="7" class="obs-estado">A carregar observações…</td>
        </tr>
      </tbody>
    </table>
  </div>

  <p id="sem-resultados" class="obs-estado" style="display:none;">
    Nenhuma observação corresponde aos filtros seleccionados.
  </p>

  <nav id="paginacao" class="obs-paginacao" style="display:none;" aria-label="Paginação">
    <button id="pag-anterior" class="obs-pag-btn">‹ Anterior</button>
    <span id="pag-info" class="obs-pag-info"></span>
    <button id="pag-seguinte" class="obs-pag-btn">Seguinte ›</button>
  </nav>

  <div id="totais-especie" class="obs-totais" style="display:none;">
    <h2 class="obs-totais-titulo">Totais por espécie</h2>
    <div id="totais-lista" class="obs-chips"></div>
  </div>

  <script>
  (function () {
    var ESPECIE_URLS = {{ collections.especies | especieUrlsJson | safe }};
    var FAMILIA_MAP  = {{ collections.especies | familiaMapJson | safe }};

    var PAGE_SIZE = 50;
    var allData = [];
    var filteredData = [];
    var currentPage = 0;
    var familiaEspecies = {}; // familia → [nome_cientifico, ...]

    var selEspecie    = document.getElementById('filtro-especie');
    var selFamilia    = document.getElementById('filtro-familia');
    var selAno        = document.getElementById('filtro-ano');
    var selObservador = document.getElementById('filtro-observador');
    var btnLimpar     = document.getElementById('limpar-filtros');
    var contagemEl    = document.getElementById('contagem-obs');
    var semResultados = document.getElementById('sem-resultados');
    var tbody         = document.getElementById('obs-tbody');
    var paginacao     = document.getElementById('paginacao');
    var pagInfo       = document.getElementById('pag-info');
    var pagAnterior   = document.getElementById('pag-anterior');
    var pagSeguinte   = document.getElementById('pag-seguinte');
    var totaisDiv     = document.getElementById('totais-especie');
    var totaisLista   = document.getElementById('totais-lista');

    function addOption(select, value, label) {
      var opt = document.createElement('option');
      opt.value = value;
      opt.textContent = label || value;
      select.appendChild(opt);
    }

    function populateSelects(data) {
      var especies    = new Set();
      var familias    = new Set();
      var anos        = new Set();
      var observadors = new Set();
      data.forEach(function (o) {
        if (o.nome_cientifico) especies.add(o.nome_cientifico);
        var fam = FAMILIA_MAP[o.nome_cientifico];
        if (fam) {
          familias.add(fam);
          if (!familiaEspecies[fam]) familiaEspecies[fam] = new Set();
          familiaEspecies[fam].add(o.nome_cientifico);
        }
        if (o.data) anos.add(o.data.substring(0, 4));
        if (o.observador) observadors.add(o.observador);
      });
      Array.from(familias).sort().forEach(function (v) { addOption(selFamilia, v); });
      Array.from(anos).sort().reverse().forEach(function (v) { addOption(selAno, v); });
      Array.from(observadors).sort().forEach(function (v) { addOption(selObservador, v); });

      // Stats
      document.getElementById('stat-total').textContent = data.length;
      document.getElementById('stat-especies').textContent = especies.size;
      document.getElementById('stat-observadores').textContent = observadors.size;
      document.getElementById('obs-stats').style.display = '';
    }

    function atualizarSelectEspecies(familia) {
      selEspecie.innerHTML = '';
      if (!familia) {
        addOption(selEspecie, '', '— escolha uma família —');
        selEspecie.disabled = true;
        return;
      }
      addOption(selEspecie, '', 'Todas');
      var lista = familiaEspecies[familia];
      if (lista) {
        Array.from(lista).sort().forEach(function (v) { addOption(selEspecie, v); });
      }
      selEspecie.disabled = false;
    }

    function renderPage() {
      var start = currentPage * PAGE_SIZE;
      var slice = filteredData.slice(start, start + PAGE_SIZE);
      var frag  = document.createDocumentFragment();

      slice.forEach(function (o) {
        var tr = document.createElement('tr');

        var familia = FAMILIA_MAP[o.nome_cientifico] || '';
        var url     = ESPECIE_URLS[o.nome_cientifico];
        var qtd     = o.quantidade || 1;

        var nomeHtml = url
          ? '<a href="' + url + '"><em>' + esc(o.nome_cientifico) + '</em></a>'
          : '<em>' + esc(o.nome_cientifico) + '</em>';

        var utmHtml = o.utm1k
          ? '<code class="obs-utm">' + esc(o.utm1k) + '</code>'
          : '—';

        tr.innerHTML =
          '<td class="obs-col-data">' + esc(o.data || '') + '</td>' +
          '<td>' + nomeHtml + '</td>' +
          '<td class="obs-col-secundario">' + esc(familia || '—') + '</td>' +
          '<td>' + utmHtml + '</td>' +
          '<td class="obs-col-num">' + qtd + '</td>' +
          '<td>' + esc(o.observador || '—') + '</td>' +
          '<td class="obs-col-secundario">' + esc(o.notas || '—') + '</td>';

        frag.appendChild(tr);
      });

      tbody.innerHTML = '';
      tbody.appendChild(frag);

      var total = filteredData.length;
      var totalPages = Math.ceil(total / PAGE_SIZE);
      if (totalPages > 1) {
        paginacao.style.display = 'flex';
        pagInfo.textContent = 'Página ' + (currentPage + 1) + ' de ' + totalPages;
        pagAnterior.disabled = currentPage === 0;
        pagSeguinte.disabled = currentPage >= totalPages - 1;
      } else {
        paginacao.style.display = 'none';
      }
    }

    function filtrar() {
      var vEsp = selEspecie.value;
      var vFam = selFamilia.value;
      var vAno = selAno.value;
      var vObs = selObservador.value;
      var temFiltro = vEsp || vFam || vAno || vObs;

      btnLimpar.style.display = temFiltro ? '' : 'none';

      filteredData = allData.filter(function (o) {
        return (!vEsp || o.nome_cientifico === vEsp)
            && (!vFam || FAMILIA_MAP[o.nome_cientifico] === vFam)
            && (!vAno || (o.data && o.data.substring(0, 4) === vAno))
            && (!vObs || o.observador === vObs);
      });

      currentPage = 0;
      renderPage();

      var visiveis = filteredData.length;
      contagemEl.textContent = temFiltro
        ? visiveis + ' observaç' + (visiveis !== 1 ? 'ões' : 'ão')
        : '';

      semResultados.style.display = visiveis === 0 ? '' : 'none';

      if (temFiltro && visiveis > 0) {
        var totais = {};
        filteredData.forEach(function (o) {
          totais[o.nome_cientifico] = (totais[o.nome_cientifico] || 0) + (o.quantidade || 1);
        });
        totaisDiv.style.display = '';
        totaisLista.innerHTML = '';
        Object.keys(totais).sort(function (a, b) { return totais[b] - totais[a]; }).forEach(function (sp) {
          var chip = document.createElement('span');
          chip.className = 'obs-chip';
          chip.innerHTML = '<em>' + esc(sp) + '</em> <strong>' + totais[sp] + '</strong>';
          totaisLista.appendChild(chip);
        });
      } else {
        totaisDiv.style.display = 'none';
      }
    }

    function esc(str) {
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    pagAnterior.addEventListener('click', function () {
      if (currentPage > 0) { currentPage--; renderPage(); window.scrollTo(0, 0); }
    });
    pagSeguinte.addEventListener('click', function () {
      if (currentPage < Math.ceil(filteredData.length / PAGE_SIZE) - 1) { currentPage++; renderPage(); window.scrollTo(0, 0); }
    });
    selEspecie.addEventListener('change', filtrar);
    selFamilia.addEventListener('change', function () {
      atualizarSelectEspecies(selFamilia.value);
      filtrar();
    });
    selAno.addEventListener('change', filtrar);
    selObservador.addEventListener('change', filtrar);
    btnLimpar.addEventListener('click', function () {
      selFamilia.value = '';
      atualizarSelectEspecies('');
      selAno.value = '';
      selObservador.value = '';
      filtrar();
    });

    fetch('/dados/observacoes.json')
      .then(function (r) { return r.json(); })
      .then(function (data) {
        data.sort(function (a, b) {
          return (b.data || '').localeCompare(a.data || '');
        });
        allData = data;
        filteredData = data;
        populateSelects(data);
        filtrar();
        document.getElementById('obs-subtitulo').textContent = 'Registo do Grupo icarus — ' + data.length + ' observações.';
      })
      .catch(function (err) {
        tbody.innerHTML = '<tr><td colspan="7" class="obs-estado">Erro ao carregar observações.</td></tr>';
        console.error(err);
      });
  })();
  </script>

</div>
