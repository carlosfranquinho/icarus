---
layout: layouts/base.njk
title: "Atividades"
descricao: "Registo das saídas e sessões de observação de borboletas do Grupo icarus."
permalink: /atividades/
---
<div class="container">
  <header style="margin-bottom:2rem;">
    <h1 class="titulo-secao">Atividades</h1>
    <p class="subtitulo">{{ collections.posts.length }} registos de saídas e sessões de observação</p>
  </header>

  <ul class="lista-posts">
    {% for post in collections.posts %}
    <li class="lista-post-item">
      <div class="lista-post-data">
        <time datetime="{{ post.date | htmlDateString }}">{{ post.date | dataPortugues }}</time>
        {% if post.data.categoria %}
        <br><span class="categoria-badge badge-{{ post.data.categoria }}">{{ post.data.categoria }}</span>
        {% endif %}
      </div>
      <div>
        <p class="lista-post-titulo"><a href="{{ post.url }}">{{ post.data.title }}</a></p>
        {% if post.data.descricao %}
        <p class="lista-post-resumo">{{ post.data.descricao }}</p>
        {% endif %}
      </div>
    </li>
    {% endfor %}
  </ul>
</div>
