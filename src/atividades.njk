---
layout: layouts/base.njk
title: "Atividades"
descricao: "Registo das saídas e sessões de observação de borboletas do Grupo icarus."
pagination:
  data: collections.posts
  size: 15
  alias: postsPage
permalink: "/atividades/{% if pagination.pageNumber > 0 %}{{ pagination.pageNumber + 1 }}/{% endif %}index.html"
---
<div class="container">
  <header style="margin-bottom:2rem;">
    <h1 class="titulo-secao">Atividades</h1>
    <p class="subtitulo">{{ collections.posts.length }} registos de saídas e sessões de observação</p>
  </header>

  <ul class="lista-posts">
    {% for post in postsPage %}
    <li>
      <a href="{{ post.url }}" class="lista-post-card">
        {% if post.data.imagem %}
        <div class="lista-post-card-img">
          {% image post.data.imagem, post.data.title, "", "(max-width: 600px) 100vw, 300px" %}
        </div>
        {% endif %}
        <div class="lista-post-card-corpo">
          <div class="lista-post-card-meta">
            <time datetime="{{ post.date | htmlDateString }}">{{ post.date | dataPortugues }}</time>
            {% if post.data.categoria %}
            <span class="categoria-badge badge-{{ post.data.categoria }}">{{ post.data.categoria }}</span>
            {% endif %}
          </div>
          <p class="lista-post-card-titulo">{{ post.data.title }}</p>
          {% if post.data.descricao %}
          <p class="lista-post-card-resumo">{{ post.data.descricao }}</p>
          {% endif %}
          {% if post.data.local %}
          <p class="lista-post-card-local">{{ post.data.local }}</p>
          {% endif %}
        </div>
      </a>
    </li>
    {% endfor %}
  </ul>

  {% if pagination.hrefs.length > 1 %}
  <nav class="paginacao" aria-labelledby="paginacao-label">
    <h2 id="paginacao-label" class="sr-only" style="position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0,0,0,0); border:0;">Páginas</h2>
    <ul style="display: flex; list-style: none; gap: 0.5rem; justify-content: center; margin-top: 2rem;">
      {% if pagination.href.previous %}
        <li><a class="btn-hero btn-secundario has-black-color" href="{{ pagination.href.previous }}" style="border-color: var(--cinza-borda); color: var(--cinza-texto);">← Anterior</a></li>
      {% endif %}
      
      {% if pagination.href.next %}
        <li><a class="btn-hero btn-secundario has-black-color" href="{{ pagination.href.next }}" style="border-color: var(--cinza-borda); color: var(--cinza-texto);">Seguinte →</a></li>
      {% endif %}
    </ul>
  </nav>
  {% endif %}
</div>
