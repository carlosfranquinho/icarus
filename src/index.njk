---
layout: layouts/base.njk
title: "Borboletas da Marinha Grande e Leiria"
---
<section class="hero" style="background-image: url('{{ site.imagem_padrao }}'); background-size: cover; background-position: center;">
  <div class="container hero-inner" style="grid-template-columns: 1fr; text-align: center; max-width: 800px;">
    <div class="hero-texto">
      <h1 style="font-size: 3rem; margin-bottom: 1rem;">{{ site.nome }}</h1>
      <p style="font-size: 1.25rem; opacity: 1; margin-bottom: 2rem; color: #f8fafc;">{{ site.descricao }}</p>
      <div class="hero-botoes" style="justify-content: center; gap: 1rem;">
        <a href="/borboletas-diurnas/" class="btn-hero btn-primario" style="padding: 0.75rem 1.5rem; font-size: 1.05rem;">Borboletas diurnas</a>
        <a href="/borboletas-noturnas/" class="btn-hero btn-secundario" style="padding: 0.75rem 1.5rem; font-size: 1.05rem;">Borboletas noturnas</a>
      </div>
    </div>
  </div>
</section>

<div class="container">

  <div class="homepage-grid">

    <section class="secao-homepage">
      <div class="secao-header">
        <h2><span class="badge-tipo badge-diurnas-lg">☀</span> Sessões diurnas</h2>
        <a href="/atividades/" class="ver-mais-link">ver todas →</a>
      </div>
      <ul class="lista-posts-home">
        {% for post in collections.postsDiurnas | slice(5) %}
        <li>
          <a href="{{ post.url }}">
            {% if post.data.imagem %}
            {% image post.data.imagem, post.data.title %}
            {% endif %}
            <div>
              <time datetime="{{ post.date | htmlDateString }}">{{ post.date | dataPortugues }}</time>
              <strong>{{ post.data.title }}</strong>
              {% if post.data.local %}<span class="local">{{ post.data.local }}</span>{% endif %}
            </div>
          </a>
        </li>
        {% endfor %}
      </ul>
    </section>

    <section class="secao-homepage">
      <div class="secao-header">
        <h2><span class="badge-tipo badge-noturnas-lg">☾</span> Sessões noturnas</h2>
        <a href="/atividades/" class="ver-mais-link">ver todas →</a>
      </div>
      <ul class="lista-posts-home">
        {% for post in collections.postsNoturnas | slice(5) %}
        <li>
          <a href="{{ post.url }}">
            {% if post.data.imagem %}
            {% image post.data.imagem, post.data.title %}
            {% endif %}
            <div>
              <time datetime="{{ post.date | htmlDateString }}">{{ post.date | dataPortugues }}</time>
              <strong>{{ post.data.title }}</strong>
              {% if post.data.local %}<span class="local">{{ post.data.local }}</span>{% endif %}
            </div>
          </a>
        </li>
        {% endfor %}
      </ul>
    </section>

  </div>

  <section class="secao-familias">
    <div class="secao-header">
      <h2>Fichas de espécies</h2>
    </div>
    <div class="familias-dois-grupos">
      <div>
        <h3 class="grupo-titulo">☀ Diurnas</h3>
        <div class="grelha-familias-home">
          {% for familia in collections.familiasDiurnas | sort(false, false, 'data.title') %}
          <a href="{{ familia.url }}" class="card-familia-home">
            {% if familia.data.imagem %}
            {% image familia.data.imagem, familia.data.title %}
            {% endif %}
            <span>{{ familia.data.title }}</span>
          </a>
          {% endfor %}
        </div>
      </div>
      <div>
        <h3 class="grupo-titulo">☾ Noturnas</h3>
        <div class="grelha-familias-home">
          {% for familia in collections.familiasNoturnas | sort(false, false, 'data.title') %}
          <a href="{{ familia.url }}" class="card-familia-home">
            {% if familia.data.imagem %}
            {% image familia.data.imagem, familia.data.title %}
            {% endif %}
            <span>{{ familia.data.title }}</span>
          </a>
          {% endfor %}
        </div>
      </div>
    </div>
  </section>

</div>
