---
layout: layouts/base.njk
ogType: article
---
<div class="container">
  <div class="conteudo-central">
    <article>
      {% if imagem %}<img src="{{ imagem }}" alt="" data-pagefind-meta="image[src]" style="position:absolute;width:0;height:0;overflow:hidden;">{% endif %}
      <header class="post-cabecalho">
        {% if imagem %}
        <div class="post-cabecalho-img">
          {% image imagem, title, "post-imagem-destaque" %}
        </div>
        {% endif %}
        <div class="post-cabecalho-info">
          <h1>{{ title }}</h1>
          <div class="post-meta">
            {% if date %}
            <span class="post-meta-item">
              <time datetime="{{ date | htmlDateString }}">{{ date | dataPortugues }}</time>
            </span>
            {% endif %}
            {% if categoria %}
            <span class="categoria-badge badge-{{ categoria }}">{{ categoria }}</span>
            {% endif %}
            {% if local %}
            <span class="post-meta-item">📍 {{ local }}</span>
            {% endif %}
            {% if participantes %}
            <span class="post-meta-item">👥 {{ participantes }}</span>
            {% endif %}
          </div>
        </div>
      </header>

      <div class="post-corpo">
        {{ content | safe }}
      </div>

      {% set eventoAnterior = collections.posts | getNextCollectionItem %}
      {% set eventoSeguinte = collections.posts | getPreviousCollectionItem %}
      {% if eventoAnterior or eventoSeguinte %}
      <nav class="post-nav" aria-label="Navegação entre eventos">
        <div class="post-nav-anterior">
          {% if eventoAnterior %}
          <a href="{{ eventoAnterior.url }}">
            <span class="post-nav-label">← Evento anterior</span>
            <span class="post-nav-titulo">{{ eventoAnterior.data.title }}</span>
          </a>
          {% endif %}
        </div>
        <div class="post-nav-seguinte">
          {% if eventoSeguinte %}
          <a href="{{ eventoSeguinte.url }}">
            <span class="post-nav-label">Evento seguinte →</span>
            <span class="post-nav-titulo">{{ eventoSeguinte.data.title }}</span>
          </a>
          {% endif %}
        </div>
      </nav>
      {% endif %}
    </article>
  </div>
</div>
