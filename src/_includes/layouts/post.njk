---
layout: layouts/base.njk
ogType: article
---
<div class="container">
  <div class="conteudo-central">
    <article>
      {% if imagem %}<span hidden data-pagefind-meta="image" content="{{ imagem }}"></span>{% endif %}
      <header class="post-cabecalho">
        {% if imagem %}
        <div class="post-cabecalho-img">
          {% image imagem, title, "post-imagem-destaque" %}
        </div>
        {% endif %}
        <div class="post-cabecalho-info">
          <h1>{{ title }}</h1>
          <div class="post-meta">
            {% if date %}
            <span class="post-meta-item">
              <time datetime="{{ date | htmlDateString }}">{{ date | dataPortugues }}</time>
            </span>
            {% endif %}
            {% if categoria %}
            <span class="categoria-badge badge-{{ categoria }}">{{ categoria }}</span>
            {% endif %}
            {% if local %}
            <span class="post-meta-item">📍 {{ local }}</span>
            {% endif %}
            {% if participantes %}
            <span class="post-meta-item">👥 {{ participantes }}</span>
            {% endif %}
          </div>
        </div>
      </header>

      <div class="post-corpo">
        {{ content | safe }}
      </div>
    </article>
  </div>
</div>
