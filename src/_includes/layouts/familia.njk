---
layout: layouts/base.njk
---
<div class="container">
  <nav aria-label="Caminho" style="font-size:0.85rem; color: var(--cor-texto-suave); margin-bottom:1.5rem;">
    <a href="/">Início</a> ›
    {% if grupo == "diurnas" %}
    <a href="/borboletas-diurnas/">Borboletas diurnas</a>
    {% elif grupo == "noturnas" %}
    <a href="/borboletas-noturnas/">Borboletas noturnas</a>
    {% endif %}
    › {{ title }}
  </nav>

  <div class="familia-topo">
    <h1 class="titulo-secao">{{ title }}</h1>
    {% if especies.length %}
    <span class="num-especies">{{ especies.length }} espécie{% if especies.length != 1 %}s{% endif %}</span>
    {% endif %}
  </div>

  {% if content and content | trim %}
  <div class="pagina-conteudo" style="margin-bottom:2rem;">
    {{ content | safe }}
  </div>
  {% endif %}

  <div class="grelha-especies">
    {% for especie in collections.especiesDiurnas if especie.data.familia == title %}
    {% set especie = especie %}
    {% include "partials/especie-card.njk" %}
    {% endfor %}
    {% for especie in collections.especiesNoturnas if especie.data.familia == title %}
    {% set especie = especie %}
    {% include "partials/especie-card.njk" %}
    {% endfor %}
  </div>
</div>
