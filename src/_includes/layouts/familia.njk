---
layout: layouts/base.njk
---
<div class="container">
  <nav class="breadcrumb" aria-label="Caminho">
    <a href="/">Início</a> ›
    {% if grupo == "diurnas" %}
    <a href="/borboletas-diurnas/">Borboletas diurnas</a>
    {% elif grupo == "noturnas" %}
    <a href="/borboletas-noturnas/">Borboletas noturnas</a>
    {% elif grupo == "micro" %}
    <a href="/microborboletas/">Microborboletas</a>
    {% endif %}
    › {{ title }}
  </nav>

  <header class="familia-header">
    {% if imagem %}
    <div class="familia-hero"{% if cor_thumb %} style="background-color: {{ cor_thumb }}"{% endif %}>
      <div class="familia-hero-titulo">
        <h1>{{ title }}</h1>
      </div>
      {% image imagem, title, "familia-hero-img" %}
    </div>
    {% else %}
    <h1 class="titulo-secao">{{ title }}</h1>
    {% endif %}
  </header>

  {% if content and content | trim %}
  <div class="pagina-conteudo familia-descricao">
    {{ content | safe }}
  </div>
  {% endif %}

  {% if grupo == "diurnas" %}
    {% set especiesAqui = collections.especiesDiurnas | porFamilia(title) %}
  {% elif grupo == "micro" %}
    {% set especiesAqui = collections.especiesMicro | porFamilia(title) %}
  {% else %}
    {% set especiesAqui = collections.especiesNoturnas | porFamilia(title) %}
  {% endif %}

  {% if especiesAqui.length %}
  <p class="num-especies-texto">
    {{ especiesAqui.length }} espécie{% if especiesAqui.length != 1 %}s{% endif %} registada{% if especiesAqui.length != 1 %}s{% endif %}
  </p>
  <div class="grelha-especies">
    {% for especie in especiesAqui %}
    <article class="card-especie">
      {% if especie.data.imagem %}
      <a href="{{ especie.url }}" tabindex="-1" aria-hidden="true">
        {% image especie.data.imagem, especie.data.nome_cientifico, "card-especie-img", "(max-width: 600px) 100vw, 300px" %}
      </a>
      {% endif %}
      <div class="card-especie-corpo">
        <h3><a href="{{ especie.url }}">{{ especie.data.nome_cientifico }}</a></h3>
        {% if especie.data.nome_comum %}
        <p class="card-especie-comum">{{ especie.data.nome_comum }}</p>
        {% endif %}
        {% set nObs = especie | totalObsEspecie(obsCount) %}
        {% if nObs > 0 %}
        <p class="card-especie-obs">{{ nObs }} obs.</p>
        {% endif %}
      </div>
    </article>
    {% endfor %}
  </div>
  {% else %}
  <p class="sem-especies">Ainda não há fichas de espécies para esta família.</p>
  {% endif %}
</div>
