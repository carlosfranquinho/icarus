---
layout: layouts/base.njk
---
<div class="container">
  <nav class="breadcrumb" aria-label="Caminho">
    <a href="/">Início</a> ›
    {% if grupo == "diurnas" %}
    <a href="/borboletas-diurnas/">Borboletas diurnas</a>
    {% elif grupo == "noturnas" %}
    <a href="/borboletas-noturnas/">Borboletas noturnas</a>
    {% endif %}
    › {{ title }}
  </nav>

  <header class="familia-header">
    {% if imagem %}
    <div class="familia-hero" style="background-image: url('{{ imagem }}')">
      <div class="familia-hero-overlay">
        <h1>{{ title }}</h1>
      </div>
    </div>
    {% else %}
    <h1 class="titulo-secao">{{ title }}</h1>
    {% endif %}
  </header>

  {% if content and content | trim %}
  <div class="pagina-conteudo familia-descricao">
    {{ content | safe }}
  </div>
  {% endif %}

  {% if grupo == "diurnas" %}
    {% set especiesAqui = collections.especiesDiurnas | porFamilia(title) %}
  {% else %}
    {% set especiesAqui = collections.especiesNoturnas | porFamilia(title) %}
  {% endif %}

  {% if especiesAqui.length %}
  <p class="num-especies-texto">
    {{ especiesAqui.length }} espécie{% if especiesAqui.length != 1 %}s{% endif %} registada{% if especiesAqui.length != 1 %}s{% endif %}
  </p>
  <div class="grelha-especies">
    {% for especie in especiesAqui %}
    {% include "partials/especie-card.njk" %}
    {% endfor %}
  </div>
  {% else %}
  <p class="sem-especies">Ainda não há fichas de espécies para esta família.</p>
  {% endif %}
</div>
