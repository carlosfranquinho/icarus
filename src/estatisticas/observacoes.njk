---
layout: layouts/base.njk
title: "Estatísticas — Observações"
descricao: "Análise estatística das observações de campo do Grupo icarus: evolução anual, sazonalidade, mapa de distribuição e grupos."
permalink: /estatisticas/observacoes/
extraCSS:
  - https://unpkg.com/leaflet@1.9.4/dist/leaflet.css
---
<div class="container">

  <header class="est-header">
    <div>
      <a href="/observacoes/" class="est-volta">← Observações</a>
      <h1 class="titulo-secao">Estatísticas</h1>
    </div>
    <nav class="est-nav" aria-label="Secções de estatísticas">
      <a href="/estatisticas/observacoes/" class="est-nav-tab activo">Observações</a>
      <a href="/estatisticas/especies/" class="est-nav-tab">Espécies</a>
      <a href="/estatisticas/observadores/" class="est-nav-tab">Observadores</a>
    </nav>
  </header>

  <div class="est-hero" id="est-hero" style="display:none;">
    <div class="est-hero-stat">
      <span class="est-hero-stat-valor" id="sh-total">—</span>
      <span class="est-hero-stat-label">observações totais</span>
    </div>
    <div class="est-hero-stat">
      <span class="est-hero-stat-valor" id="sh-anos">—</span>
      <span class="est-hero-stat-label">anos de actividade</span>
    </div>
    <div class="est-hero-stat">
      <span class="est-hero-stat-valor" id="sh-quadriculas">—</span>
      <span class="est-hero-stat-label">quadrículas visitadas</span>
    </div>
    <div class="est-hero-stat">
      <span class="est-hero-stat-valor" id="sh-obs">—</span>
      <span class="est-hero-stat-label">observadores</span>
    </div>
    <div class="est-hero-stat">
      <span class="est-hero-stat-valor" id="sh-mes-pico">—</span>
      <span class="est-hero-stat-label">mês de pico</span>
    </div>
  </div>

  <p class="est-loading" id="est-loading">A carregar dados…</p>

  <div id="est-conteudo" style="display:none;">
    <div class="est-grid">

      <div class="est-card est-card-largo">
        <p class="est-card-titulo">Observações por ano</p>
        <p class="est-card-subtitulo">Evolução do número de registos ao longo do tempo</p>
        <div class="est-chart-wrap">
          <canvas id="g-por-ano"></canvas>
        </div>
      </div>

      <div class="est-card">
        <p class="est-card-titulo">Actividade mensal</p>
        <p class="est-card-subtitulo">Padrão sazonal — total acumulado por mês do ano</p>
        <div class="est-chart-wrap">
          <canvas id="g-por-mes"></canvas>
        </div>
      </div>

      <div class="est-card">
        <p class="est-card-titulo">Diurnas vs noturnas</p>
        <p class="est-card-subtitulo">Distribuição das observações por grupo</p>
        <div class="est-chart-wrap">
          <canvas id="g-grupos"></canvas>
        </div>
      </div>

      <div class="est-card est-card-largo">
        <p class="est-card-titulo">Distribuição geográfica</p>
        <p class="est-card-subtitulo">Quadrículas UTM 1×1 km — intensidade proporcional ao número de observações (escala logarítmica)</p>
        <div id="mapa-obs" class="est-mapa"></div>
        <div class="est-mapa-legenda">
          <span class="est-legenda-cor" style="background:#bae6fd;"></span> poucas
          <span class="est-legenda-cor" style="background:#0891b2; margin-left:0.75rem;"></span> médias
          <span class="est-legenda-cor" style="background:#164e63; margin-left:0.75rem;"></span> muitas
        </div>
      </div>

    </div>
  </div>

  <script>
  (function () {
    var ESPECIE_META = {{ collections.especies | especieMetaJson | safe }};
    var MESES       = ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
    var MESES_LONGO = ['Janeiro','Fevereiro','Março','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];

    function carregarScript(src, testFn, cb) {
      if (testFn()) { cb(); return; }
      var s = document.createElement('script');
      s.src = src;
      s.onload = cb;
      document.head.appendChild(s);
    }

    fetch('/dados/observacoes.json')
      .then(function (r) { return r.json(); })
      .then(function (dados) {
        // Ambas as libs carregam em paralelo com os mesmos dados
        carregarScript(
          'https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js',
          function () { return !!window.Chart; },
          function () { inicializarGraficos(dados); }
        );
        carregarScript(
          'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js',
          function () { return !!window.L; },
          function () { inicializarMapa(dados); }
        );
        inicializarHero(dados);
      })
      .catch(function () {
        document.getElementById('est-loading').textContent = 'Erro ao carregar dados.';
      });

    // ── Hero stats ─────────────────────────────────────────────────────
    function inicializarHero(dados) {
      var porMes = Array(12).fill(0);
      var anosSet = new Set(), utmSet = new Set(), obsSet = new Set();
      dados.forEach(function (o) {
        if (o.data) {
          anosSet.add(o.data.substring(0, 4));
          var mes = parseInt(o.data.substring(5, 7), 10) - 1;
          if (mes >= 0 && mes < 12) porMes[mes] += (o.quantidade || 1);
        }
        if (o.utm1k) utmSet.add(o.utm1k.substring(0, 6));
        if (o.observador) obsSet.add(o.observador);
      });
      var mesPico = porMes.indexOf(Math.max.apply(null, porMes));
      document.getElementById('sh-total').textContent       = dados.length.toLocaleString('pt-PT');
      document.getElementById('sh-anos').textContent        = anosSet.size;
      document.getElementById('sh-quadriculas').textContent = utmSet.size;
      document.getElementById('sh-obs').textContent         = obsSet.size;
      document.getElementById('sh-mes-pico').textContent    = MESES_LONGO[mesPico];
      document.getElementById('est-hero').style.display     = '';
      document.getElementById('est-loading').style.display  = 'none';
      document.getElementById('est-conteudo').style.display = '';
    }

    // ── Gráficos Chart.js ──────────────────────────────────────────────
    function inicializarGraficos(dados) {
      var porAno = {}, porMes = Array(12).fill(0);
      var porGrupo = { diurnas: 0, noturnas: 0, outro: 0 };
      dados.forEach(function (o) {
        var qtd = o.quantidade || 1;
        if (o.data) {
          var ano = o.data.substring(0, 4);
          var mes = parseInt(o.data.substring(5, 7), 10) - 1;
          porAno[ano] = (porAno[ano] || 0) + qtd;
          if (mes >= 0 && mes < 12) porMes[mes] += qtd;
        }
        var meta = ESPECIE_META[o.nome_cientifico];
        if (meta && meta.grupo === 'diurnas')       porGrupo.diurnas  += (o.quantidade || 1);
        else if (meta && meta.grupo === 'noturnas') porGrupo.noturnas += (o.quantidade || 1);
        else                                         porGrupo.outro    += (o.quantidade || 1);
      });

      Chart.defaults.font.family = 'system-ui, sans-serif';
      Chart.defaults.font.size   = 11;
      var grid = 'rgba(100,116,139,0.12)', tick = '#94a3b8';

      function optsVBar() {
        return { responsive: true, maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            x: { grid: { display: false }, ticks: { color: tick } },
            y: { grid: { color: grid },    ticks: { color: tick } }
          }
        };
      }

      // Gráfico 1: por ano
      var anos = Object.keys(porAno).sort();
      new Chart(document.getElementById('g-por-ano'), {
        type: 'bar',
        data: { labels: anos, datasets: [{ data: anos.map(function (a) { return porAno[a]; }),
          backgroundColor: '#0891b2', borderRadius: 4 }] },
        options: optsVBar()
      });

      // Gráfico 2: por mês (intensidade)
      var maxMes = Math.max.apply(null, porMes);
      new Chart(document.getElementById('g-por-mes'), {
        type: 'bar',
        data: { labels: MESES, datasets: [{ data: porMes,
          backgroundColor: porMes.map(function (v) {
            return 'rgba(8,145,178,' + (0.2 + 0.8 * v / maxMes).toFixed(2) + ')';
          }),
          borderRadius: 4 }] },
        options: optsVBar()
      });

      // Gráfico 3: diurnas vs noturnas
      new Chart(document.getElementById('g-grupos'), {
        type: 'doughnut',
        data: { labels: ['Diurnas', 'Noturnas', 'Sem ficha'],
          datasets: [{ data: [porGrupo.diurnas, porGrupo.noturnas, porGrupo.outro],
            backgroundColor: ['#f59e0b', '#6366f1', '#e2e8f0'],
            borderWidth: 2, borderColor: '#ffffff' }] },
        options: { responsive: true, maintainAspectRatio: false, cutout: '65%',
          plugins: { legend: { position: 'bottom',
            labels: { color: '#64748b', padding: 14, font: { size: 12 } } } } }
      });
    }

    // ── Mapa Leaflet heatmap ───────────────────────────────────────────
    // Funções UTM → LatLon (idênticas às das fichas de espécies)
    var A = 6378137.0, E2 = 0.00669437999014, K0 = 0.9996;
    var LON0 = -9 * Math.PI / 180;

    function utmToLatLon(E, N) {
      var e1  = (1 - Math.sqrt(1 - E2)) / (1 + Math.sqrt(1 - E2));
      var e2p = E2 / (1 - E2);
      var M   = N / K0;
      var mu  = M / (A * (1 - E2/4 - 3*Math.pow(E2,2)/64 - 5*Math.pow(E2,3)/256));
      var phi1 = mu
        + (3*e1/2 - 27*Math.pow(e1,3)/32) * Math.sin(2*mu)
        + (21*Math.pow(e1,2)/16 - 55*Math.pow(e1,4)/32) * Math.sin(4*mu)
        + (151*Math.pow(e1,3)/96) * Math.sin(6*mu)
        + (1097*Math.pow(e1,4)/512) * Math.sin(8*mu);
      var N1 = A / Math.sqrt(1 - E2*Math.pow(Math.sin(phi1),2));
      var T1 = Math.pow(Math.tan(phi1),2);
      var C1 = e2p * Math.pow(Math.cos(phi1),2);
      var R1 = A*(1-E2) / Math.pow(1-E2*Math.pow(Math.sin(phi1),2), 1.5);
      var D  = (E - 500000) / (N1 * K0);
      var lat = phi1 - (N1*Math.tan(phi1)/R1) * (
        Math.pow(D,2)/2
        - (5+3*T1+10*C1-4*Math.pow(C1,2)-9*e2p)*Math.pow(D,4)/24
        + (61+90*T1+298*C1+45*Math.pow(T1,2)-252*e2p-3*Math.pow(C1,2))*Math.pow(D,6)/720
      );
      var lon = LON0 + (
        D
        - (1+2*T1+C1)*Math.pow(D,3)/6
        + (5-2*C1+28*T1-3*Math.pow(C1,2)+8*e2p+24*Math.pow(T1,2))*Math.pow(D,5)/120
      ) / Math.cos(phi1);
      return [lat * 180/Math.PI, lon * 180/Math.PI];
    }

    var COL = {J:0,K:1,L:2,M:3,N:4,P:5,Q:6,R:7};
    var ROW = {A:0,B:1,C:2,D:3,E:4,F:5,G:6,H:7,J:8,K:9,L:10,M:11,N:12,P:13,Q:14,R:15,S:16,T:17,U:18,V:19};
    var N_CYCLE = 4000000;

    function utm1kToBounds(code) {
      if (!code || code.length < 6) return null;
      var colIdx = COL[code[0]], rowIdx = ROW[code[1]];
      if (colIdx === undefined || rowIdx === undefined) return null;
      var sqE = parseInt(code.substring(2, 4), 10);
      var sqN = parseInt(code.substring(4, 6), 10);
      var E_sw = (colIdx + 1) * 100000 + sqE * 1000;
      var N_sw = N_CYCLE + rowIdx * 100000 + sqN * 1000;
      return [utmToLatLon(E_sw, N_sw), utmToLatLon(E_sw + 1000, N_sw + 1000)];
    }

    // Cor do heatmap: escala log entre azul claro (#bae6fd) e azul escuro (#164e63)
    function heatColor(count, maxCount) {
      var t = Math.log(count + 1) / Math.log(maxCount + 1);
      var r = Math.round(186 + (22  - 186) * t);
      var g = Math.round(230 + (78  - 230) * t);
      var b = Math.round(253 + (99  - 253) * t);
      return 'rgb(' + r + ',' + g + ',' + b + ')';
    }

    function inicializarMapa(dados) {
      // Agregar por quadrícula completa (6 chars)
      var squares = {};
      dados.forEach(function (o) {
        if (o.utm1k && o.utm1k.length >= 6) {
          var code = o.utm1k.substring(0, 6);
          squares[code] = (squares[code] || 0) + (o.quantidade || 1);
        }
      });

      var maxCount = Math.max.apply(null, Object.values(squares));

      var AREA_ESTUDO = [[39.46, -9.05], [39.88, -8.61]];
      var map = L.map('mapa-obs', {
        maxBounds: AREA_ESTUDO,
        maxBoundsViscosity: 1.0,
        minZoom: 9
      });
      map.fitBounds(AREA_ESTUDO);

      L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
        attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors © <a href="https://carto.com/">CARTO</a>',
        maxZoom: 19
      }).addTo(map);

      // Perímetro dos concelhos
      fetch('/assets/places/concelhos.geojson')
        .then(function (r) { return r.json(); })
        .then(function (data) {
          L.geoJSON(data, { style: { color: '#15803d', weight: 1, fillOpacity: 0 }, interactive: false }).addTo(map);
        });

      // Quadrículas com cor proporcional à intensidade
      Object.keys(squares).forEach(function (code) {
        var bounds = utm1kToBounds(code);
        if (!bounds) return;
        var count = squares[code];
        var cor   = heatColor(count, maxCount);
        L.rectangle(bounds, {
          color:       cor,
          weight:      1,
          fillColor:   cor,
          fillOpacity: 0.75
        }).bindTooltip(
          '<strong>' + code + '</strong><br>' + count + ' observaç' + (count !== 1 ? 'ões' : 'ão'),
          { sticky: true }
        ).addTo(map);
      });
    }
  })();
  </script>

</div>
