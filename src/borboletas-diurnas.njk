---
layout: layouts/base.njk
title: "Borboletas diurnas"
descricao: "Fichas de identificação das borboletas diurnas (Rhopalocera) observadas na Marinha Grande, Leiria, Batalha e Porto de Mós."
permalink: /borboletas-diurnas/
---
<div class="container">
  <header class="pagina-cabecalho">
    <h1 class="titulo-secao">Borboletas diurnas</h1>
    <p class="subtitulo">Rhopalocera — fichas de identificação por família</p>
  </header>

  <div class="grelha-familias-fichas">
    {% for familia in collections.familiasDiurnas | sort(false, false, 'data.title') %}
    {% set nespecies = collections.especiesDiurnas | porFamilia(familia.data.title) %}
    <a href="{{ familia.url }}" class="card-familia-ficha">
      {% if familia.data.imagem %}
      <div class="card-familia-ficha-img" style="background-image: url('{{ familia.data.imagem }}')"></div>
      {% else %}
      <div class="card-familia-ficha-img card-familia-ficha-img--vazio"></div>
      {% endif %}
      <div class="card-familia-ficha-corpo">
        <h2>{{ familia.data.title }}</h2>
        <p class="card-familia-ficha-num">{{ nespecies.length }} espécie{% if nespecies.length != 1 %}s{% endif %}</p>
        {% if familia.data.descricao %}<p class="card-familia-ficha-desc">{{ familia.data.descricao }}</p>{% endif %}
      </div>
    </a>
    {% endfor %}
  </div>
</div>
